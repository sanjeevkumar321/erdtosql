{
  "redirects": [
    {
      "source": "/((?!\\.well-known/acme-challenge/).*)",
      "has": [
        {
          "type": "header",
          "key": "x-forwarded-proto",
          "value": "http"
        }
      ],
      "destination": "https://$host/$1",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/((?!\\.well-known/acme-challenge/).*)",
      "destination": "/index.html"
    }
  ]
}
